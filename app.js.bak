const app = document.getElementById('app');

function paperCard(paper, idx) {
  return `
    <article class="paper-card">
      <div class="rank">${idx + 1}</div>
      <h3><a href="${paper.url}" target="_blank" rel="noreferrer">${paper.title}</a></h3>
      <p>${paper.note}</p>
      <a href="${paper.url}" target="_blank" rel="noreferrer">Open paper</a>
    </article>
  `;
}

function daySection(day, index) {
  const hiddenId = `all-${index}`;
  return `
    <section class="day-card">
      <div class="day-header">
        <div>
          <h2>${day.date}</h2>
          <div class="meta">Top 5 picks plus ${day.all.length} listed papers available below</div>
        </div>
      </div>

      <div class="top5">
        ${day.top5.map(paperCard).join('')}
      </div>

      <div class="actions">
        <button class="toggle" data-target="${hiddenId}">See all papers</button>
      </div>

      <div id="${hiddenId}" class="all-list hidden">
        <ul>
          ${day.all.map(([title, url]) => `<li><a href="${url}" target="_blank" rel="noreferrer">${title}</a></li>`).join('')}
        </ul>
      </div>
    </section>
  `;
}

app.innerHTML = `
  ${digestData.map(daySection).join('')}
  <p class="footer-note">This site is currently seeded with the latest three daily digests and can be extended to update automatically each day.</p>
`;

document.querySelectorAll('.toggle').forEach((button) => {
  button.addEventListener('click', () => {
    const target = document.getElementById(button.dataset.target);
    const isHidden = target.classList.toggle('hidden');
    button.textContent = isHidden ? 'See all papers' : 'Hide full list';
  });
});
